        </optgroup>
        <optgroup label="PULL — Jueves">
          <option data-s="4" data-r="10">Jalón al pecho agarre ancho</option>
          <option data-s="4" data-r="12">Jalón agarre neutro</option>
          <option data-s="4" data-r="10">Remo máquina / polea baja</option>
