    <div class="fr3">
      <div class="fg"><label>Series</label><input type="number" id="ex-s" value="3" min="1" max="10" inputmode="numeric"></div>
      <div class="fg"><label>Reps</label><input type="number" id="ex-r" value="10" min="1" inputmode="numeric"></div>
      <div class="fg"><label>Unidad</label><select id="ex-u"><option value="reps">reps</option><option value="seg">seg</option><option value="min">min</option></select></div>
    </div>
    <div class="fg"><label>Peso usado (kg) · 0 = peso corporal</label><input type="number" id="ex-w" value="0" step="0.5" min="0" inputmode="decimal"></div>
    <div class="fg"><label>Nota rápida</label><input type="text" id="ex-n" placeholder="Sensación, técnica…"></div>
    <div class="modal-actions">
