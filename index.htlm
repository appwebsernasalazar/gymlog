          <option data-s="3" data-r="10">Zancada atrás mancuernas</option>
          <option data-s="3" data-r="12">Curl femoral máquina</option>
          <option data-s="3" data-r="12">Extensión cuádriceps máquina</option>
          <option data-s="3" data-r="20">Abducción glúteo máquina</option>
