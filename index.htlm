// =================== STORAGE ===================
function load(k){try{return JSON.parse(localStorage.getItem(k))||[];}catch(e){return[];}}
function save(k,v){localStorage.setItem(k,JSON.stringify(v));}
var sesiones=load('gl_ses');
var medidas=load('gl_med');
var exTemp=[];
var currentSession=null;

// =================== NAV ===================
var titles={home:'Inicio',sesion:'Nueva sesión',historial:'Historial',medidas:'Medidas',plan:'Mi plan',metodo:'Metodología'};

function goTo(id){
  document.querySelectorAll('.screen').forEach(function(s){s.classList.remove('active');});
  document.querySelectorAll('.bn-item').forEach(function(b){b.classList.remove('active');});
  var screen=document.getElementById('screen-'+id);
  var btn=document.getElementById('bn-'+id);
  if(screen) screen.classList.add('active');
  if(btn) btn.classList.add('active');
  document.getElementById('page-title').textContent=titles[id]||'';
  document.getElementById('content').scrollTop=0;
  if(id==='home') renderDash();
  if(id==='historial') renderHist();
  if(id==='medidas') renderMed();
  if(id==='plan') renderPlan();
}

// Wire up bottom nav
document.querySelectorAll('.bn-item').forEach(function(btn){
  btn.addEventListener('click',function(){
    goTo(this.getAttribute('data-screen'));
  });
});

// =================== DASHBOARD ===================
function renderDash(){
  var h=new Date().getHours();
  document.getElementById('dash-greeting').textContent=(h<12?'Buenos días':h<20?'Buenas tardes':'Buenas noches')+' 👋';
  document.getElementById('dash-date').textContent=new Date().toLocaleDateString('es-ES',{weekday:'long',year:'numeric',month:'long',day:'numeric'});
  document.getElementById('d-ses').textContent=sesiones.length;

  var ps=sesiones.filter(function(s){return s.peso;}).sort(function(a,b){return new Date(b.fecha)-new Date(a.fecha);});
  if(ps.length){
    var p=ps[0].peso;
    document.getElementById('d-peso').textContent=p;
    document.getElementById('d-imc').textContent=(p/(1.78*1.78)).toFixed(1);
  }

  var hoy=new Date();var lun=new Date(hoy);lun.setDate(hoy.getDate()-((hoy.getDay()+6)%7));lun.setHours(0,0,0,0);
  document.getElementById('d-sem').textContent=sesiones.filter(function(s){return new Date(s.fecha)>=lun;}).length;

  var tipos=['','Lunes','Martes','Miércoles','Jueves','Viernes',''];
  var dow=new Date().getDay();var ni=dow;
  for(var i=0;i<7;i++){var idx=(dow+i)%7;if(tipos[idx]){ni=idx;break;}}
  var pd=PLAN.find(function(p){return p.dia===tipos[ni];});
  var dn=document.getElementById('d-next');
  if(pd){
    dn.innerHTML='<div class="next-card"><div class="next-dot" style="background:'+pd.color+';"></div><div class="next-info"><div class="next-name">'+pd.dia+' — '+pd.tipo+'</div><div class="next-sub">'+pd.sub+'</div></div><button class="btn btn-p btn-sm" id="btn-start-session">Empezar →</button></div>';
    document.getElementById('btn-start-session').addEventListener('click',function(){goTo('sesion');});
  }

  var rec=[].concat(sesiones).sort(function(a,b){return new Date(b.fecha)-new Date(a.fecha);}).slice(0,3);
  var dr=document.getElementById('d-recent');
  if(!rec.length){
    dr.innerHTML='<div class="empty"><div class="empty-ico">📋</div><div class="empty-txt">Sin sesiones todavía</div></div>';
  } else {
    dr.innerHTML=rec.map(function(s){
      return '<div class="list-item" data-id="'+s.id+'"><div class="li-title">'+s.tipo+'</div><div class="li-sub">'+new Date(s.fecha+'T12:00:00').toLocaleDateString('es-ES',{weekday:'short',day:'numeric',month:'short'})+(s.semana?' · '+s.semana:'')+'</div><div class="li-meta">'+(s.ejercicios?s.ejercicios.length+' ejercicios':'')+' '+(s.duracion?'· '+s.duracion+' min':'')+' '+(s.rpe?'· RPE '+s.rpe+'/10':'')+'</div></div>';
    }).join('');
    dr.querySelectorAll('.list-item').forEach(function(el){
      el.addEventListener('click',function(){showDet(this.getAttribute('data-id'));});
    });
  }

  var pd2=[].concat(sesiones).filter(function(s){return s.peso;}).sort(function(a,b){return new Date(a.fecha)-new Date(b.fecha);}).slice(-8).map(function(s){return parseFloat(s.peso);});
  var sp=document.getElementById('d-spark');
  if(pd2.length>1){
    var mn=Math.min.apply(null,pd2),mx=Math.max.apply(null,pd2),rng=mx-mn||1;
    sp.className='spark';
    sp.innerHTML=pd2.map(function(v){return '<div class="spark-bar" style="height:'+Math.max(Math.round(((v-mn)/rng)*100),8)+'%;"></div>';}).join('');
    var delta=(pd2[pd2.length-1]-pd2[0]).toFixed(1);
    document.getElementById('d-trend').innerHTML='<span style="color:'+(delta<0?'var(--green)':'var(--red)')+';">'+(delta>0?'+':'')+delta+' kg desde la primera medición</span>';
  } else {
    sp.innerHTML='';
    document.getElementById('d-trend').textContent='Registra tu peso en sesiones para ver la evolución';
  }
}

// =================== SESIÓN ===================
document.getElementById('s-fecha').value=new Date().toISOString().split('T')[0];

document.getElementById('btn-add-ex').addEventListener('click',function(){
  document.getElementById('ex-sel').value='';
  document.getElementById('ex-cn').value='';
  document.getElementById('cg').style.display='none';
  document.getElementById('ex-s').value='3';
  document.getElementById('ex-r').value='10';
  document.getElementById('ex-u').value='reps';
  document.getElementById('ex-w').value='0';
  document.getElementById('ex-n').value='';
  openModal('modal-ex');
});

document.getElementById('ex-sel').addEventListener('change',function(){
  var sel=this;
  var opt=sel.options[sel.selectedIndex];
  if(sel.value==='__custom__'){
    document.getElementById('cg').style.display='block';
  } else {
    document.getElementById('cg').style.display='none';
    if(opt&&opt.dataset.s) document.getElementById('ex-s').value=opt.dataset.s;
    if(opt&&opt.dataset.r) document.getElementById('ex-r').value=opt.dataset.r;
    document.getElementById('ex-u').value=(opt&&opt.dataset.unit)||'reps';
  }
});

document.getElementById('btn-cancel-ex').addEventListener('click',function(){closeModal('modal-ex');});
document.getElementById('btn-confirm-ex').addEventListener('click',function(){
  var sel=document.getElementById('ex-sel');
  var nombre=sel.value==='__custom__'?document.getElementById('ex-cn').value.trim():sel.value;
  if(!nombre){alert('Selecciona o escribe un ejercicio');return;}
  exTemp.push({nombre:nombre,series:parseInt(document.getElementById('ex-s').value)||3,reps:parseInt(document.getElementById('ex-r').value)||10,unit:document.getElementById('ex-u').value,peso:parseFloat(document.getElementById('ex-w').value)||0,notas:document.getElementById('ex-n').value});
  renderExList();
  closeModal('modal-ex');
  toast('Ejercicio añadido ✓');
});

function renderExList(){
  var el=document.getElementById('ex-list');
  if(!exTemp.length){
    el.innerHTML='<div class="empty"><div class="empty-ico">🏋️</div><div class="empty-txt">Pulsa "+ Añadir" para empezar</div></div>';
    return;
  }
  el.innerHTML=exTemp.map(function(e,i){
    return '<div class="ex-row"><div class="ex-info"><div class="ex-name">'+e.nombre+'</div><div class="ex-detail">'+e.series+' series × '+e.reps+' '+e.unit+(e.notas?' · '+e.notas:'')+'</div></div><div class="ex-kg">'+(e.peso?e.peso+' kg':'PC')+'</div><button class="btn btn-sm btn-d" data-i="'+i+'" style="min-height:36px;padding:6px 10px;">✕</button></div>';
  }).join('');
  el.querySelectorAll('button[data-i]').forEach(function(btn){
    btn.addEventListener('click',function(){exTemp.splice(parseInt(this.getAttribute('data-i')),1);renderExList();});
  });
}

document.getElementById('btn-guardar-ses').addEventListener('click',function(){
  var fecha=document.getElementById('s-fecha').value;
  if(!fecha){alert('Selecciona una fecha');return;}
  if(!exTemp.length&&!confirm('¿Guardar sesión sin ejercicios?')) return;
  var s={
    id:Date.now().toString(),
    fecha:fecha,
    tipo:document.getElementById('s-tipo').value,
    semana:document.getElementById('s-semana').value,
    notas:document.getElementById('s-notas').value,
    ejercicios:[].concat(exTemp),
    peso:parseFloat(document.getElementById('s-peso').value)||null,
    duracion:parseInt(document.getElementById('s-dur').value)||null,
    rpe:parseInt(document.getElementById('s-rpe').value)||null
  };
  sesiones.push(s);
  save('gl_ses',sesiones);
  exTemp=[];
  ['s-notas','s-peso','s-dur','s-rpe'].forEach(function(id){document.getElementById(id).value='';});
  renderExList();
  toast('Sesión guardada ✓');
  setTimeout(function(){goTo('historial');},600);
});

// =================== HISTORIAL ===================
function renderHist(){
  document.getElementById('hist-sub').textContent=sesiones.length+' sesiones registradas';
  var hl=document.getElementById('hist-list');
  if(!sesiones.length){
    hl.innerHTML='<div class="empty"><div class="empty-ico">📂</div><div class="empty-txt">Sin sesiones registradas</div></div>';
    return;
  }
  var sorted=[].concat(sesiones).sort(function(a,b){return new Date(b.fecha)-new Date(a.fecha);});
  hl.innerHTML=sorted.map(function(s){
    return '<div class="list-item" data-id="'+s.id+'"><div class="li-title">'+s.tipo+'</div><div class="li-sub">'+new Date(s.fecha+'T12:00:00').toLocaleDateString('es-ES',{weekday:'long',day:'numeric',month:'long',year:'numeric'})+(s.semana?' · '+s.semana:'')+'</div><div class="li-meta">'+(s.ejercicios?s.ejercicios.length+' ejercicios':'')+' '+(s.duracion?'· '+s.duracion+' min':'')+' '+(s.rpe?'· RPE '+s.rpe+'/10':'')+' '+(s.peso?'· '+s.peso+' kg':'')+'</div>'+(s.notas?'<div style="font-size:12px;color:var(--t3);margin-top:3px;font-style:italic;">'+s.notas+'</div>':'')+'</div>';
  }).join('');
  hl.querySelectorAll('.list-item').forEach(function(el){
    el.addEventListener('click',function(){showDet(this.getAttribute('data-id'));});
  });
}

function showDet(id){
  var s=sesiones.find(function(x){return x.id===id;});
  if(!s) return;
  document.getElementById('det-title').textContent=s.tipo;
  var statsHtml='';
  if(s.duracion||s.rpe||s.peso){
    statsHtml='<div style="display:grid;grid-template-columns:repeat(3,1fr);gap:8px;margin-bottom:10px;">';
    if(s.duracion) statsHtml+='<div class="stat"><div class="stat-val" style="font-size:20px;">'+s.duracion+'</div><div class="stat-lbl">min</div></div>';
    if(s.rpe) statsHtml+='<div class="stat"><div class="stat-val" style="font-size:20px;">'+s.rpe+'/10</div><div class="stat-lbl">RPE</div></div>';
    if(s.peso) statsHtml+='<div class="stat"><div class="stat-val" style="font-size:20px;">'+s.peso+'</div><div class="stat-lbl">kg</div></div>';
    statsHtml+='</div>';
  }
  var notaHtml=s.notas?'<div style="background:var(--bg3);border-radius:var(--r);padding:10px 12px;font-size:13px;color:var(--t2);margin-bottom:10px;font-style:italic;">'+s.notas+'</div>':'';
  var exHtml=s.ejercicios&&s.ejercicios.length?s.ejercicios.map(function(e){
    return '<div class="ex-row"><div class="ex-info"><div class="ex-name">'+e.nombre+'</div><div class="ex-detail">'+e.series+'×'+e.reps+' '+e.unit+(e.notas?' · '+e.notas:'')+'</div></div><div class="ex-kg">'+(e.peso?e.peso+' kg':'PC')+'</div></div>';
  }).join(''):'<div style="color:var(--t3);font-size:13px;padding:8px 0;">Sin ejercicios registrados</div>';
  document.getElementById('det-content').innerHTML='<div style="font-size:12px;color:var(--t3);margin-bottom:10px;">'+new Date(s.fecha+'T12:00:00').toLocaleDateString('es-ES',{weekday:'long',day:'numeric',month:'long',year:'numeric'})+(s.semana?' · '+s.semana:'')+'</div>'+statsHtml+notaHtml+exHtml;
  document.getElementById('det-del').onclick=function(){
    if(confirm('¿Eliminar esta sesión?')){
      sesiones=sesiones.filter(function(x){return x.id!==id;});
      save('gl_ses',sesiones);
      closeModal('modal-det');
      renderHist();
      toast('Sesión eliminada');
    }
  };
  openModal('modal-det');
}

document.getElementById('btn-reset').addEventListener('click',function(){
  if(confirm('¿Borrar TODOS los datos? Esta acción no se puede deshacer.')){
    localStorage.clear();location.reload();
  }
});

// =================== MEDIDAS ===================
document.getElementById('btn-add-med').addEventListener('click',function(){
  document.getElementById('m-fecha').value=new Date().toISOString().split('T')[0];
  ['m-peso','m-cin','m-pec','m-cad','m-bra','m-mus','m-not'].forEach(function(id){document.getElementById(id).value='';});
  openModal('modal-med');
});

document.getElementById('btn-cancel-med').addEventListener('click',function(){closeModal('modal-med');});
document.getElementById('btn-confirm-med').addEventListener('click',function(){
  var m={
    id:Date.now().toString(),
    fecha:document.getElementById('m-fecha').value,
    peso:parseFloat(document.getElementById('m-peso').value)||null,
    cintura:parseFloat(document.getElementById('m-cin').value)||null,
    pecho:parseFloat(document.getElementById('m-pec').value)||null,
    cadera:parseFloat(document.getElementById('m-cad').value)||null,
    brazo:parseFloat(document.getElementById('m-bra').value)||null,
    muslo:parseFloat(document.getElementById('m-mus').value)||null,
    notas:document.getElementById('m-not').value
  };
  if(!m.fecha){alert('Selecciona una fecha');return;}
  medidas.push(m);
  save('gl_med',medidas);
  closeModal('modal-med');
  renderMed();
  toast('Medidas guardadas ✓');
});

function renderMed(){
  var sorted=[].concat(medidas).sort(function(a,b){return new Date(b.fecha)-new Date(a.fecha);});
  var last=sorted[0],prev=sorted[1];
  var md=document.getElementById('med-display');
  if(!last){
    md.innerHTML='<div class="empty"><div class="empty-ico">📏</div><div class="empty-txt">Sin medidas aún</div></div>';
  } else {
    var campos=[{k:'peso',l:'Peso',u:'kg',d:true},{k:'cintura',l:'Cintura',u:'cm',d:true},{k:'pecho',l:'Pecho',u:'cm',d:false},{k:'cadera',l:'Cadera',u:'cm',d:true},{k:'brazo',l:'Brazo',u:'cm',d:false},{k:'muslo',l:'Muslo',u:'cm',d:false}].filter(function(c){return last[c.k];});
    md.innerHTML='<div style="font-size:12px;color:var(--t3);margin-bottom:10px;">'+new Date(last.fecha+'T12:00:00').toLocaleDateString('es-ES',{day:'numeric',month:'long',year:'numeric'})+'</div><div class="med-grid">'+campos.map(function(c){var v=last[c.k];var delta=prev&&prev[c.k]?(v-prev[c.k]).toFixed(1):null;var good=delta!==null?(c.d?delta<0:delta>0):null;return '<div class="med-card"><div><span class="med-val">'+v+'</span><span class="med-unit"> '+c.u+'</span></div><div class="med-lbl">'+c.l+'</div>'+(delta!==null?'<div class="med-delta '+(good?'dd':'du')+'">'+(delta>0?'+':'')+delta+' '+c.u+'</div>':'')+'</div>';}).join('')+'</div>'+(last.notas?'<div style="margin-top:10px;font-size:12px;color:var(--t3);font-style:italic;">'+last.notas+'</div>':'');
  }
  var mh=document.getElementById('med-hist');
  if(!sorted.length){mh.innerHTML='';return;}
  mh.innerHTML=sorted.map(function(m){
    return '<div class="list-item" style="cursor:default;"><div class="li-sub">'+new Date(m.fecha+'T12:00:00').toLocaleDateString('es-ES',{day:'numeric',month:'short',year:'2-digit'})+'</div><div style="display:flex;gap:12px;flex-wrap:wrap;margin-top:4px;">'+(m.peso?'<span style="font-size:13px;"><strong>'+m.peso+'</strong> kg</span>':'')+''+(m.cintura?'<span style="font-size:13px;">Cin: <strong>'+m.cintura+'</strong></span>':'')+''+(m.brazo?'<span style="font-size:13px;">Bra: <strong>'+m.brazo+'</strong></span>':'')+'</div><button class="btn btn-sm btn-d" data-mid="'+m.id+'" style="margin-top:8px;">Eliminar</button></div>';
  }).join('');
  mh.querySelectorAll('button[data-mid]').forEach(function(btn){
    btn.addEventListener('click',function(){
      if(!confirm('¿Eliminar esta medición?')) return;
      medidas=medidas.filter(function(m){return m.id!==this.getAttribute('data-mid');},this);
      save('gl_med',medidas);renderMed();toast('Eliminada');
    });
  });
}

// =================== PLAN ===================
function renderPlan(){
  var pd=document.getElementById('plan-days');
  pd.innerHTML=PLAN.map(function(d,i){
    return '<div class="plan-day"><div class="plan-day-hdr" data-i="'+i+'"><div class="plan-dot" style="background:'+d.color+';"></div><div class="plan-info"><div class="plan-day-name">'+d.dia+' — '+d.tipo+'</div><div class="plan-day-sub">'+d.sub+'</div></div><span class="plan-chevron" id="chev-'+i+'">▼</span></div><div class="plan-exs" id="plan-e-'+i+'">'+(d.nota?'<div style="font-size:12px;color:var(--amber);background:var(--abg);border-radius:6px;padding:7px 10px;margin-bottom:10px;">'+d.nota+'</div>':'')+'<div style="display:grid;grid-template-columns:1fr auto;gap:4px;font-size:10px;color:var(--t3);padding:3px 0 6px;font-weight:700;text-transform:uppercase;letter-spacing:0.06em;border-bottom:1px solid var(--border);margin-bottom:4px;"><span>Ejercicio</span><span>Pesos kg</span></div>'+d.exs.map(function(e){return '<div class="plan-ex-row"><div><div class="plan-ex-name">'+e.n+'</div><div class="plan-ex-series">'+e.s+'</div></div><div class="plan-weights"><span class="pw pw1">'+e.p1+'</span><span class="pw pw2">'+e.p2+'</span><span class="pw pw3">'+e.p3+'</span></div></div>';}).join('')+'</div></div>';
  }).join('');
  pd.querySelectorAll('.plan-day-hdr').forEach(function(hdr){
    hdr.addEventListener('click',function(){
      var i=this.getAttribute('data-i');
      var exs=document.getElementById('plan-e-'+i);
      var chev=document.getElementById('chev-'+i);
      exs.classList.toggle('open');
      chev.classList.toggle('open');
    });
  });
}

// =================== MODALES ===================
function openModal(id){document.getElementById(id).classList.add('open');}
function closeModal(id){document.getElementById(id).classList.remove('open');}

document.querySelectorAll('.modal-ov').forEach(function(m){
  m.addEventListener('click',function(e){if(e.target===this) this.classList.remove('open');});
});
document.getElementById('btn-close-det').addEventListener('click',function(){closeModal('modal-det');});

// =================== TOAST ===================
function toast(msg){
  var t=document.getElementById('toast');
  t.textContent=msg;t.classList.add('show');
  setTimeout(function(){t.classList.remove('show');},2200);
}

// =================== INIT ===================
renderDash();
</script>
</body>
</html>
