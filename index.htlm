          <option data-s="3" data-r="12">Press pecho máquina</option>
          <option data-s="3" data-r="12">Remo en polea</option>
          <option data-s="3" data-r="10">Step up al cajón</option>
          <option data-s="3" data-r="20">Abducción glúteo</option>
          <option data-s="3" data-r="10">Press hombro mancuernas</option>
        </optgroup>
        <optgroup label="CARDIO — Miércoles">
          <option data-s="1" data-r="30" data-unit="min">Trote continuo</option>
          <option data-s="1" data-r="20" data-unit="min">HIIT escaladora</option>
          <option data-s="1" data-r="40" data-unit="min">Bici estática LISS</option>
          <option data-s="1" data-r="40" data-unit="min">Elíptica LISS</option>
        </optgroup>
        <option value="__custom__">✏️ Ejercicio personalizado</option>
