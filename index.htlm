          <option data-s="3" data-r="15">Face pull cuerda</option>
          <option data-s="3" data-r="12">Curl bíceps barra [SS]</option>
          <option data-s="3" data-r="12">Tríceps cuerda [SS]</option>
          <option data-s="3" data-r="12">Curl martillo mancuernas</option>
          <option data-s="3" data-r="12">Pallof press</option>
          <option data-s="3" data-r="10">Dead bug</option>
